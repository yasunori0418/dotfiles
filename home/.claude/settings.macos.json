{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": false,
  "askUserQuestionTimeout": "never",
  "cleanupPeriodDays": 876000,
  "editorMode": "vim",
  "effortLevel": "high",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    },
    "worktrunk": {
      "source": {
        "repo": "max-sixty/worktrunk",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "cchook -event Notification",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "cchook -event PostToolUse",
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "cchook -event PreCompact",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "cchook -event PreToolUse",
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "cchook -event SessionEnd",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "cchook -event SessionStart",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "cchook -event Stop",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "cchook -event SubagentStop",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "mcpServers": {
    "tirith": {
      "args": [
        "mcp-server"
      ],
      "command": "tirith"
    }
  },
  "model": "claude-opus-4-7",
  "outputStyle": "karakuchi",
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "ExitPlanMode",
      "Glob",
      "Grep",
      "LSP",
      "NotebookEdit",
      "Read",
      "Skill",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "TodoWrite",
      "ToolSearch",
      "WebSearch",
      "Write",
      "mcp__notion__notion-fetch"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "KillShell",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(sudo:*)",
      "Bash(aws:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Edit(.env*)",
      "Edit(**/secrets/**)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)"
    ]
  },
  "preferredNotifChannel": "ghostty",
  "promptSuggestionEnabled": false,
  "showClearContextOnPlanAccept": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "bunx ccusage statusline",
    "padding": 0,
    "type": "command"
  },
  "teammateMode": "auto",
  "tui": "default",
  "verbose": true
}
